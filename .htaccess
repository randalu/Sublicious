<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization / XSRF headers
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Serve Vite-compiled assets from public/build/
    RewriteCond %{REQUEST_URI} ^/build/
    RewriteRule ^build/(.+)$ public/build/$1 [L,QSA]

    # Serve uploaded/storage files from public/storage/
    RewriteCond %{REQUEST_URI} ^/storage/
    RewriteRule ^storage/(.+)$ public/storage/$1 [L,QSA]

    # Serve any other static file that exists inside public/ (favicon, manifest, sw.js …)
    RewriteCond %{DOCUMENT_ROOT}/public/%{REQUEST_FILENAME} -f
    RewriteRule ^(.+)$ public/$1 [L,QSA]

    # Redirect trailing slashes
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Route all remaining requests through root index.php (Laravel)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
